# Supabase Configuration
# Get these from your Supabase project settings: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Google Calendar Integration (Optional)
# For automatic workout publishing to Google Calendar
# Get credentials from Google Cloud Console: https://console.cloud.google.com/
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"
GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com

# Stripe Payment Integration
# Get credentials from Stripe Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your-secret-key-here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here

# Stripe Price IDs (create products in Stripe Dashboard first)
STRIPE_PRICE_MONTHLY_ID=price_your-monthly-price-id
STRIPE_PRICE_YEARLY_ID=price_your-yearly-price-id
STRIPE_PRICE_10CARD_ID=price_your-10card-price-id

# Web Push Notifications (Optional)
VAPID_SUBJECT=mailto:admin@your-domain.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key-here
VAPID_PRIVATE_KEY=your-vapid-private-key-here

# Resend Email Service
# Get API key from https://resend.com/api-keys
RESEND_API_KEY=re_your-api-key-here
# Use onboarding@resend.dev for testing, custom domain after verification
EMAIL_FROM=onboarding@resend.dev

# App URL (for Stripe redirects and email links - set to your deployed domain in production)
NEXT_PUBLIC_APP_URL=https://app.the-forge-functional-fitness.de
